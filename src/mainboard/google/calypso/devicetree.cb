# CBI UFSC fields
fw_config
	field STORAGE_TYPE 12 14
		option STORAGE_TYPE_UNKNOWN	0
		option STORAGE_TYPE_NVME	1
		option STORAGE_TYPE_UFS	2
	end
end

chip soc/qualcomm/calypso
	device cpu_cluster 0 on end
	device domain 0 on
		device pci 00.0 on end # Root Bridge
	end
end
