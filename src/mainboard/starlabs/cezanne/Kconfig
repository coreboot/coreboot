	default n

config VARIANT_DIR
	default "starbook"		if BOARD_STARLABS_STARBOOK_CEZANNE
	default "byte"			if BOARD_STARLABS_BYTE_CEZANNE

config EFS_SPI_SPEED
	default 3	# 66MHz

config NORMAL_READ_SPI_SPEED
	default 1	# 33MHz

