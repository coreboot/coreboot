	default "starlabs/cezanne"

config MAINBOARD_FAMILY
	default "B6-A"			if BOARD_STARLABS_STARBOOK_CEZANNE
	default "Y1"			if BOARD_STARLABS_BYTE_CEZANNE

config MAINBOARD_PART_NUMBER
	default "StarBook Mk VI"	if BOARD_STARLABS_STARBOOK_CEZANNE
	default "Byte Mk I"		if BOARD_STARLABS_BYTE_CEZANNE

